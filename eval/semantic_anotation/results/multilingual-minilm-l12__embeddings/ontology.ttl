@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix geolinkeddata: <http://geo.linkeddata.es/ontology/> .
@prefix ogc: <http://www.ogc.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/ontology/AU_UnidadesAdministrativas> a owl:Class ;
    rdfs:label "AU Unidades administrativas" ;
    rdfs:comment "Unidad de administración sobre la que un Estado miembro tiene y/o ejerce derechos jurisdiccionales para el gobierno local, regional y nacional." ;
    rdfs:subClassOf schema1:AdministrativeArea .

<http://example.org/ontology/HY-P_Esclusa> a owl:Class ;
    rdfs:label "HY-P Esclusa" ;
    rdfs:comment "Recinto con un par o una serie de puertas utilizado para hacer subir o bajar a los buques que pasan de un nivel de agua a otro." ;
    rdfs:subClassOf schema1:CivicStructure .

<http://example.org/ontology/NZ_Riesgo_a_la_poblacion_Q500> a owl:Class ;
    rdfs:label "NZ.Riesgo a la población Q500" ;
    rdfs:subClassOf schema1:MedicalRiskEstimator .

geolinkeddata:HY-P_Cuenca_de_captación a owl:Class ;
    rdfs:label "HY-P Cuenca de captación" ;
    rdfs:comment "Zona que tiene un desagüe común para su escorrentía." ;
    rdfs:subClassOf geolinkeddata:Captación .

geolinkeddata:HY_N_Secuencia_de_enlaces_de_curso_de_agua a owl:Class ;
    rdfs:label "HY-N Secuencia de enlaces de curso de agua" ;
    rdfs:comment "Secuencia de enlaces de curso de agua que representa una trayectoria sin ramificación a través de una red hidrográfica." ;
    rdfs:subClassOf geolinkeddata:Corriente .

geolinkeddata:altitud a rdf:Property ;
    rdfs:label "elevacion" ;
    rdfs:domain ogc:standingwater ;
    rdfs:range xsd:float .

geolinkeddata:longitud a rdf:Property ;
    rdfs:label "longitud" ;
    rdfs:domain ogc:watercourselinksequence ;
    rdfs:range xsd:float .

geolinkeddata:origina a rdf:Property ;
    rdfs:label "nativeness",
        "origen" ;
    rdfs:domain ogc:damorweir,
        ogc:drainagebasin,
        ogc:lock,
        ogc:standingwater,
        ogc:watercourselinksequence ;
    rdfs:range xsd:string .

schema1:HY-P_Presa_o_represa a owl:Class ;
    rdfs:label "HY-P Presa o represa" ;
    rdfs:comment "Barrera permanente a través de un curso de agua, utilizada para almacenar agua o controlar su flujo." ;
    rdfs:subClassOf schema1:CivicStructure .

ogc:administrativeunit_collection a geo:FeatureCollection ;
    rdfs:label "AU Unidades administrativas" ;
    geo:hasBoundingBox [ geo:asWKT "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POLYGON((-19,27,5,44))"^^geo:wktLiteral ] .

<http://www.ogc.org/agua:Zif_riesgo_pob_q500_collection> a geo:FeatureCollection ;
    rdfs:label "NZ.Riesgo a la población Q500" ;
    geo:hasBoundingBox [ geo:asWKT "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POLYGON((-17.9600143432617,27.7205505371094,3.37545585632324,43.7451210021973))"^^geo:wktLiteral ] .

