    rml:logicalSource <http://example.com/LogicalSource_WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnit> ;
    rml:predicateObjectMap [ rml:objectMap [ void:filterx "the_geom=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.the_geom" ] ;
            rml:predicate :the_geom ],
        [ rml:objectMap [ void:filterx "CNUT3=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CNUT3" ] ;
            rml:predicate :CNUT3 ],
        [ rml:objectMap [ void:filterx "CPRO=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CPRO" ] ;
            rml:predicate :CPRO ],
        [ rml:objectMap [ void:filterx "CUMUN=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CUMUN" ] ;
            rml:predicate :CUMUN ],
        [ rml:objectMap [ void:filterx "CNUT0=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CNUT0" ] ;
            rml:predicate :CNUT0 ],
        [ rml:objectMap [ void:filterx "CNUT2=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CNUT2" ] ;
            rml:predicate :CNUT2 ],
        [ rml:objectMap [ void:filterx "CMUN=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CMUN" ] ;
            rml:predicate :CMUN ],
        [ rml:objectMap [ rml:datatype xsd:string ;
                    rml:reference "geometry_name" ] ;
            rml:predicate :geometryName ],
        [ rml:objectMap [ void:filterx "NPRO=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.NPRO" ] ;
            rml:predicate :NPRO ],
        [ rml:objectMap [ void:filterx "bbox=@{1}" ;
                    rml:datatype geo:geoJSONLiteral ;
                    rml:reference "geometry" ] ;
            rml:predicate geo:hasGeometry ],
        [ rml:objectMap [ void:filterx "CSEC=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CSEC" ] ;
            rml:predicate :CSEC ],
        [ rml:objectMap [ void:filterx "NMUN=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.NMUN" ] ;
            rml:predicate :NMUN ],
        [ rml:objectMap [ void:filterx "NCA=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.NCA" ] ;
            rml:predicate :NCA ],
        [ rml:objectMap [ void:filterx "CLAU2=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CLAU2" ] ;
            rml:predicate :CLAU2 ],
        [ rml:objectMap [ void:filterx "CCA=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CCA" ] ;
            rml:predicate :CCA ],
        [ rml:objectMap [ void:filterx "TIPO=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.TIPO" ] ;
            rml:predicate :TIPO ],
        [ rml:objectMap [ void:filterx "CNUT1=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CNUT1" ] ;
            rml:predicate :CNUT1 ],
        [ rml:objectMap [ void:filterx "CUDIS=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CUDIS" ] ;
            rml:predicate :CUDIS ],
        [ rml:objectMap [ void:filterx "CUSEC=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.CUSEC" ] ;
            rml:predicate :CUSEC ],
        [ rml:objectMap [ void:filterx "CDIS=@{1}" ;
