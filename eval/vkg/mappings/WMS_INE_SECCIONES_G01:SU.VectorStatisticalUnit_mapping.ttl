<http://example.com/WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnitTriplesMap2> a rml:TriplesMap ;
    rml:logicalSource <http://example.com/LogicalSource_WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnit> ;
    rml:predicateObjectMap [ rml:objectMap [ rml:parentTriplesMap <http://example.com/WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnitTriplesMap> ] ;
            rml:predicate geo:member ] ;
    rml:subjectMap [ rml:class geo:FeatureCollection ;
            rml:constant <http://example.com/WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnit_collection> ] .

<http://example.com/FuenteAPI_WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnit> htv:absoluteURI "https://www.ine.es/geoserver/ogc/features/v1//collections/WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnit/items?f=json&limit=10000" .

