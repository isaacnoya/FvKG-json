    rml:predicateObjectMap [ rml:objectMap [ rml:parentTriplesMap <http://www.ogc.org/WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnitTriplesMap> ] ;
            rml:predicate geo:member ] ;
    rml:subjectMap [ rml:class geo:FeatureCollection ;
            rml:constant <http://www.ogc.org/WMS_INE_SECCIONES_G01:SU.VectorStatisticalUnit_collection> ] .

